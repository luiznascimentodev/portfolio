# ── Banco de dados ─────────────────────────────────────────────────────────────
# Local (Docker): postgresql://portfolio:portfolio@localhost:5432/portfolio
# Produção: URL do Neon.tech
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio"

# Credenciais do PostgreSQL local (docker-compose)
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio

# ── Autenticação (NextAuth v5) ─────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ── Uploadthing ────────────────────────────────────────────────────────────────
# Obter em: https://uploadthing.com/dashboard
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."
